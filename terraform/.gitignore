# Terraform ローカルステートファイル
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform プラグインキャッシュとワーキングディレクトリ
.terraform/
.terraform.lock.hcl

# 実際の変数ファイル 機密情報を含む可能性があるため追跡しない
*.tfvars
!terraform.tfvars.example

# Terraform の計画ファイル
*.tfplan

# クラッシュログ
crash.log
crash.*.log

# オーバーライドファイル
override.tf
override.tf.json
*_override.tf
*_override.tf.json
